# Production Environment Variables for Navoi Airport
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=final
POSTGRES_PORT=5432

# ============================================
# Payload CMS Configuration
# ============================================
# IMPORTANT: Change this to a random 32+ character string
PAYLOAD_SECRET=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING

# Public URL of your application
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ============================================
# Node Environment
# ============================================
NODE_ENV=production

# ============================================
# Optional: Email Configuration (for forms)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================
# Optional: S3 Storage (for media files)
# ============================================
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# ============================================
# Security Notes:
# ============================================
# 1. Never commit .env file to git
# 2. Use strong passwords (min 16 characters)
# 3. Change PAYLOAD_SECRET to a unique value
# 4. In production, use environment-specific secrets
# 5. Enable SSL/TLS in production
